#!/usr/bin/env bash
# Repo guard (COMMITTED, shared) — activate with: git config core.hooksPath hooks
# Hard-blocks direct pushes to main/master: that branch is PR-only + CI-gated.
# Fires for every worktree of this repo, and for any caller (human or agent).
# Emergency bypass (discouraged): git push --no-verify
remote="$1"
protected='^refs/heads/(main|master)$'
blocked=0
while read -r localref localsha remoteref remotesha; do
  # skip branch deletions (localsha all-zero)
  [ "$localsha" = "0000000000000000000000000000000000000000" ] && continue
  if [[ "$remoteref" =~ $protected ]]; then
    echo "" >&2
    echo "  BLOCKED: direct push to '$remoteref' on '$remote'." >&2
    echo "  '$remoteref' is PR-only (CI-gated). Do this instead:" >&2
    echo "      git push -u origin <your-feature-branch>" >&2
    echo "      gh pr create -B main -H <your-feature-branch>" >&2
    echo "  (Guard: hooks/pre-push via core.hooksPath. Real emergency only: git push --no-verify)" >&2
    echo "" >&2
    blocked=1
  fi
done
exit $blocked
